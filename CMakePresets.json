	      }
	    },
	    {
	      "name": "release-buildlib-am275-target",
	      "inherits": ["base-am275-target", "base-buildlib"],
	      "cacheVariables": {
		"CMAKE_BUILD_TYPE": "release"
	      }
	    },
	    {
	      "name": "debug-buildlib-am275-target",
